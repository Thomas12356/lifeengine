{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@pages/*": ["./src/pages/*"],
      "@features/*": ["./src/features/*"],
      "@context/*": ["./src/context/*"],
      "@ui-components/*": ["./src/components/ui-components/*"],
      "@theme/*": ["./src/theme/*"],
    }
  }
}