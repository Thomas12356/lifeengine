{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@pages/*": ["./src/components/pages/*"],
      "@sections/*": ["./src/components/sections/*"],
      "@layouts/*": ["./src/components/layouts/*"],
      "@ui-components/*": ["./src/components/ui-components/*"],
      "@resource-card-collection/*": ["./src/components/ui-components/resource-card-collection/*"],
      "@text/*" : ["./src/components/ui-components/text/*"],
      "@theme/*": ["./src/theme/*"],
    }
  }
}